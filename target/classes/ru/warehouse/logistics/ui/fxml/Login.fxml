<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="ru.warehouse.logistics.ui.controller.LoginController"
           style="-fx-background-color: #1a1d23;">

    <VBox alignment="CENTER" spacing="0">
        <VBox styleClass="login-card" spacing="20" maxWidth="380" minWidth="340">

            <VBox spacing="6" alignment="CENTER">
                <Label text="🚚" style="-fx-font-size: 36px;"/>
                <Label text="Логистика" styleClass="label-title" style="-fx-font-size: 24px;"/>
                <Label text="Поставки и графики работы" styleClass="label-muted"/>
            </VBox>

            <Separator/>

            <VBox spacing="14">
                <VBox spacing="5">
                    <Label text="ЛОГИН" styleClass="section-label"/>
                    <TextField fx:id="usernameField"
                               promptText="Введите логин"
                               maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="ПАРОЛЬ" styleClass="section-label"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="••••••••"
                                   maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label"
                   visible="false" managed="false" wrapText="true"
                   maxWidth="Infinity"/>

            <Button fx:id="loginButton"
                    text="Войти в систему"
                    styleClass="btn-primary"
                    onAction="#onLogin"
                    defaultButton="true"
                    maxWidth="Infinity"
                    style="-fx-padding: 11 0;"/>

            <StackPane>
                <ProgressIndicator fx:id="spinner"
                                   maxHeight="24" maxWidth="24"
                                   visible="false" managed="false"/>
            </StackPane>

        </VBox>

        <Label text="Warehouse Logistics v1.0"
               styleClass="label-hint"
               style="-fx-padding: 16 0 0 0;"/>
    </VBox>
</StackPane>
